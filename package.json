{
  "name": "autoline-masterclass",
  "version": "1.0.0",
  "description": "AutoLine — a Remotion masterclass on the fully automated AI video production line",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/captions": "4.0.471",
    "@remotion/cli": "4.0.471",
    "@remotion/google-fonts": "4.0.471",
    "@remotion/media": "4.0.471",
    "@remotion/paths": "4.0.471",
    "@remotion/shapes": "4.0.471",
    "@remotion/transitions": "4.0.471",
    "mediabunny": "^1.27.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.471",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.471",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "start": "remotion studio",
    "dev": "remotion studio",
    "sfx": "node scripts/make-sfx.mjs",
    "bgm": "node scripts/make-bgm.mjs",
    "bgm:piano": "node scripts/make-bgm-piano.mjs",
    "vo": "node scripts/make-vo.mjs",
    "vo:upload": "node scripts/make-vo-upload.mjs",
    "vo:aivoice": "node scripts/make-vo-aivoice.mjs",
    "vo:mcp": "node scripts/make-vo-mcp.mjs",
    "vo:claude-remote": "node scripts/make-vo-claude-remote.mjs",
    "vo:recap": "node scripts/make-vo-recap.mjs",
    "bgm:tech": "node scripts/make-bgm-tech.mjs",
    "render": "remotion render AutoUpload out/auto-upload.mp4",
    "render:autoline": "remotion render ProductionLine out/production-line.mp4",
    "render:mcp": "remotion render McpVsApi out/mcp-vs-api.mp4",
    "render:mcp-reel": "remotion render McpVsApiReel out/mcp-vs-api-reel.mp4",
    "render:claude-remote": "remotion render ClaudeRemoteNotes out/claude-remote-notes.mp4",
    "render:recap": "remotion render DailyRecap out/ai-daily-recap.mp4",
    "render:recap-reel": "remotion render DailyRecapReel out/ai-daily-recap-reel.mp4 --concurrency=2",
    "render:all": "node scripts/render-all.mjs",
    "render:paintings": "node scripts/render-paintings.mjs",
    "tsc": "tsc --noEmit",
    "lint": "eslint src && tsc"
  }
}
